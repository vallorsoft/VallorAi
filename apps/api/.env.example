# Server
NODE_ENV=development
PORT=3001

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# AI Providers
AI_PROVIDER=GEMINI
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-flash-latest
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-5
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vallorai-assets
R2_PUBLIC_URL=https://assets.yourdomain.com

# Frontend URL (for CORS + email verification links)
FRONTEND_URL=http://localhost:3000

# Email (Brevo transactional email)
BREVO_API_KEY=xkeysib-...
BREVO_SENDER=no-reply@vallorai.com
BREVO_SENDER_NAME=AI Home Designer

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// USERS & AUTH
// =====================

enum UserRole {
  GUEST
  USER
  CLIENT
  ARCHITECT
  STRUCTURAL_ENGINEER
  MEP_ENGINEER
  ELECTRICAL_ENGINEER
  CONTRACTOR
  MANUFACTURER
  SUPPLIER
  ADMIN
  SUPERADMIN
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String?
  role      UserRole @default(USER)
  plan      SubscriptionPlan @default(FREE)
  language  String   @default("ro")
  country   String   @default("RO")
  avatarUrl String?
  isVerified Boolean @default(false)
  verificationToken          String?   @unique
  verificationTokenExpiresAt DateTime?

  projects  Project[]
  sessions  Session[]
  passwordResetTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// =====================
// PROJECTS
// =====================

enum ProjectType {
  FAMILY_HOUSE
  VACATION_HOUSE
  EXTENSION
  RENOVATION
  OFFICE
  INVESTMENT
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  REVIEW
  APPROVED
  PERMIT_READY
  CONSTRUCTION
  COMPLETED
}

model Project {
  id     String        @id @default(cuid())
  userId String
  name   String
  type   ProjectType   @default(FAMILY_HOUSE)
  status ProjectStatus @default(DRAFT)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plot        Plot?
  lifestyle   Lifestyle?
  budget      Budget?
  house       House?
  messages    Message[]
  documents   Document[]
  costEstimate CostEstimate?
  versions    ProjectVersion[]
  currentVersionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Plot {
  id             String  @id @default(cuid())
  projectId      String  @unique
  country        String  @default("RO")
  county         String?
  city           String?
  address        String?
  cadastralNumber String?
  lat            Float?
  lng            Float?
  area           Float?
  slope          Float   @default(0)
  orientation    String?
  zone           String?
  hasWater       Boolean @default(false)
  hasSewage      Boolean @default(false)
  hasGas         Boolean @default(false)
  hasElectricity Boolean @default(false)
  hasInternet    Boolean @default(false)
  photos         String[]
  documents      String[]

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lifestyle {
  id               String  @id @default(cuid())
  projectId        String  @unique
  residents        Int     @default(2)
  children         Int     @default(0)
  planningChildren Boolean @default(false)
  elderlyResident  Boolean @default(false)
  mobilityImpaired Boolean @default(false)
  pets             Boolean @default(false)
  homeOffice       Boolean @default(false)
  garage           Boolean @default(false)
  pool             Boolean @default(false)
  terrace          Boolean @default(true)
  basement         Boolean @default(false)
  attic            Boolean @default(false)
  solarPanels      Boolean @default(false)
  heatPump         Boolean @default(false)
  style            String  @default("MODERN")
  favoriteColors   String[]
  additionalNotes  String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Budget {
  id        String  @id @default(cuid())
  projectId String  @unique
  currency  String  @default("RON")
  minimum   Float?
  optimal   Float?
  maximum   Float?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// HOUSE DESIGN
// =====================

model House {
  id         String @id @default(cuid())
  projectId  String @unique
  totalArea  Float  @default(0)
  floors     Int    @default(1)
  roofType   String @default("GABLED")
  version    Int    @default(1)

  rooms       Room[]
  walls       Wall[]
  openings    Opening[]
  foundations Foundation[]
  tieColumns  TieColumn[]
  centuri     Centura[]
  roof        Roof?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// PROJECT VERSIONING
// =====================

model ProjectVersion {
  id        String   @id @default(cuid())
  projectId String
  snapshot  Json
  label     String?
  createdBy String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([projectId])
}

model Room {
  id      String @id @default(cuid())
  houseId String
  type    String
  name    String
  floor   Int    @default(0)
  area    Float
  width   Float
  height  Float
  posX    Float  @default(0)
  posY    Float  @default(0)
  aiJustification String?

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@index([houseId])
}

// The house's roof. Auto-provisioned on first HousesService.getRoof() call
// from a footprint computed off the topmost floor's walls; parameters follow
// packages/bim-engine roof.ts (deriveRoofSpec) — default 35° pitch, 0.7 m
// overhang, ridge derived from footprint + pitch (see roof.ts's citation
// comment for the standard references). `pitchVerified`/`overhangVerified`
// mirror the same pattern as Foundation.depthVerified and Material.specSheet's
// priceVerified: standards-cited defaults are marked true, convention-only
// defaults false, and the UI is expected to surface the latter as unverified.
//
// `materialId` points to a `MaterialCategory.ROOFING` row (default:
// `Țiglă ceramică Tondach standard` seeded in seed.ts) — same GENERIC_DEFAULT
// vs. MANUFACTURER upgrade path the other AssemblyLayer materials follow
// once the marketplace lands.
model Roof {
  id               String   @id @default(cuid())
  houseId          String   @unique
  type             RoofType
  pitchDeg         Float
  overhangM        Float
  ridgeHeightM     Float
  pitchVerified    Boolean  @default(true)
  overhangVerified Boolean  @default(false)
  materialId       String

  house    House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([materialId])
}

model Wall {
  id         String  @id @default(cuid())
  houseId    String
  startX     Float
  startY     Float
  endX       Float
  endY       Float
  floor      Int     @default(0)
  thickness  Float   @default(0.3)
  height     Float   @default(2.7)
  isLoad     Boolean @default(false)
  isExterior Boolean @default(false)
  /// True for walls derived automatically from the room rectangles (bim-engine
  /// wall-generation) — these are deleted and re-derived on every AI room
  /// change, so nothing user-drawn may ever carry this flag.
  isGenerated Boolean @default(false)
  material   String?

  house    House     @relation(fields: [houseId], references: [id], onDelete: Cascade)
  openings Opening[]

  assemblyLayers     AssemblyLayer[]
  reinforcementSpecs ReinforcementSpec[]
  centuri            Centura[]

  @@index([houseId])
}

model Opening {
  id             String  @id @default(cuid())
  houseId        String
  wallId         String
  type           String
  position       Float
  width          Float
  height         Float
  sillHeight     Float   @default(0)
  swingDirection String?

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)
  wall  Wall  @relation(fields: [wallId], references: [id], onDelete: Cascade)
  lintel Lintel?

  @@index([houseId])
  @@index([wallId])
}

// =====================
// MATERIALS & LAYERED ASSEMBLIES (BIM-level detail)
// =====================
// AssemblyLayer/ReinforcementSpec use a nullable-FK-per-parent-type shape
// (wallId? / foundationId?) rather than a single polymorphic elementType+id
// pair, so referential integrity and cascade deletes stay real Postgres FKs.
// A CHECK constraint (added via raw SQL in the migration, since Prisma has
// no first-class polymorphic relations) enforces "exactly one parent set".

enum MaterialCategory {
  BRICK
  BLOCK
  CONCRETE
  REBAR
  MORTAR
  INSULATION
  RENDER
  PLASTER
  PAINT
  PRECAST
  ROOFING
}

// The Roof geometry types the auto-provisioning solver knows about
// (see packages/bim-engine roof.ts). MONOSLOPE / FLAT are placeholders —
// only GABLED is rendered as a real ridge+two-slopes geometry in the 3D
// viewer's first cut; the others are drawn as a flat cap until a specific
// rendering ships. `House.roofType` (a legacy string field kept for UI
// preference selection) is mirrored into `Roof.type` on auto-provision.
enum RoofType {
  GABLED
  HIPPED
  FLAT
  MONOSLOPE
}

enum MaterialUnit {
  M2
  M3
  BUC
  KG
  ML
}

enum MaterialSource {
  GENERIC_DEFAULT
  MANUFACTURER
}

enum LayerFunction {
  STRUCTURAL
  INSULATION
  RENDER
  FINISH
  PAINT
}

enum RebarRole {
  LONGITUDINAL
  STIRRUP
  TRANSVERSE
}

// S1 = corner/wall-intersection tie-column (always required).
// S2 = intermediate tie-column limiting max spacing along a run.
// S3 = tie-column flanking an opening large enough to require confinement
// in the site's seismic zone (CR6-2013: area >= 1.5 m² where ag >= 0.25g,
// >= 2.5 m² elsewhere) — see packages/bim-engine confined-masonry.ts +
// seismic.ts. Its residual-pier-length trigger remains a documented gap.
enum TieColumnCategory {
  S1
  S2
  S3
}

model Material {
  id             String           @id @default(cuid())
  category       MaterialCategory
  name           String
  standardRef    String?
  unit           MaterialUnit
  unitCostRON    Float
  specSheet      Json
  source         MaterialSource   @default(GENERIC_DEFAULT)
  supplierId     String?
  priceUpdatedAt DateTime         @default(now())

  assemblyLayers AssemblyLayer[]
  lintels        Lintel[]
  roofs          Roof[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([supplierId])
}

model Foundation {
  id            String @id @default(cuid())
  houseId       String
  depthMm       Float
  widthMm       Float
  concreteClass String

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)

  assemblyLayers     AssemblyLayer[]
  reinforcementSpecs ReinforcementSpec[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([houseId])
}

// A reinforced-concrete tie-column (stâlpișor) embedded in a masonry wall
// run, per CR6-2013 — see packages/bim-engine confined-masonry.ts for the
// S1 (corner/intersection) and S2 (max-spacing) placement rules. Owned
// directly by House (not a specific Wall) because a corner/intersection
// column is naturally shared between the two-or-more walls that meet
// there — posX/posY/floor place it in the same plan coordinates as Wall/
// Room.
model TieColumn {
  id             String            @id @default(cuid())
  houseId        String
  floor          Int               @default(0)
  posX           Float
  posY           Float
  category       TieColumnCategory
  crossSectionMm Float
  concreteClass  String

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)

  reinforcementSpecs ReinforcementSpec[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([houseId])
}

// A lintel (buiandrug) spanning one door/window Opening, bearing into the
// wall on each side — see packages/bim-engine confined-masonry.ts.
// Reinforcement is deliberately not modeled here: a prefabricated lintel's
// reinforcement is internal to the manufactured unit (referenced via
// `material`, not computed), and this project has no cited primary source
// for monolithic cast-in-place lintel reinforcement yet (see CLAUDE.md gap
// note) — not guessed.
model Lintel {
  id              String  @id @default(cuid())
  openingId       String  @unique
  materialId      String
  lengthMm        Float
  widthMm         Float
  bearingLengthMm Float
  prefabricated   Boolean @default(true)

  opening  Opening  @relation(fields: [openingId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([materialId])
}

// A reinforced-concrete ring beam (centură) tying a load-bearing wall's
// tie-columns together horizontally at one floor level — see
// packages/bim-engine centura.ts. Tied to the specific Wall whose footprint
// it follows (unlike TieColumn, a centură has real length/direction, not
// just a point) — `level` distinguishes the wall's own floor from the extra
// "above the top floor" centură this module always generates, so a wall on
// the topmost floor can have two Centura rows.
model Centura {
  id            String @id @default(cuid())
  houseId       String
  wallId        String
  level         Int
  heightMm      Float
  widthMm       Float
  concreteClass String

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)
  wall  Wall  @relation(fields: [wallId], references: [id], onDelete: Cascade)

  reinforcementSpecs ReinforcementSpec[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([houseId])
  @@index([wallId])
}

model AssemblyLayer {
  id           String        @id @default(cuid())
  wallId       String?
  foundationId String?
  order        Int
  materialId   String
  thicknessMm  Float
  function     LayerFunction

  wall       Wall?       @relation(fields: [wallId], references: [id], onDelete: Cascade)
  foundation Foundation? @relation(fields: [foundationId], references: [id], onDelete: Cascade)
  material   Material    @relation(fields: [materialId], references: [id])

  createdAt DateTime @default(now())

  @@index([wallId])
  @@index([foundationId])
  @@index([materialId])
}

model ReinforcementSpec {
  id            String    @id @default(cuid())
  wallId        String?
  foundationId  String?
  tieColumnId   String?
  centuraId     String?
  role          RebarRole
  barDiameterMm Float
  /// Center-to-center spacing for a repeating bar pattern (wall/footing mats, stirrups along a run). Not meaningful for a fixed-count arrangement — see barCount.
  spacingMm     Float
  /// Fixed bar count for an element whose reinforcement isn't a spacing-derived repeat — e.g. a tie-column's 4 corner bars. Null where spacingMm (+element geometry) already implies the count.
  barCount      Int?
  coverMm       Float
  concreteClass String

  wall       Wall?       @relation(fields: [wallId], references: [id], onDelete: Cascade)
  foundation Foundation? @relation(fields: [foundationId], references: [id], onDelete: Cascade)
  tieColumn  TieColumn?  @relation(fields: [tieColumnId], references: [id], onDelete: Cascade)
  centura    Centura?    @relation(fields: [centuraId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([wallId])
  @@index([foundationId])
  @@index([tieColumnId])
  @@index([centuraId])
}

// =====================
// AI CONVERSATION
// =====================

model Message {
  id        String @id @default(cuid())
  projectId String
  role      String
  content   String @db.Text
  metadata  Json?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([projectId])
}

// =====================
// COST & DOCUMENTS
// =====================

model CostEstimate {
  id           String  @id @default(cuid())
  projectId    String  @unique
  currency     String  @default("RON")
  foundation   Float   @default(0)
  walls        Float   @default(0)
  ceiling      Float   @default(0)
  roof         Float   @default(0)
  openings     Float   @default(0)
  mechanical   Float   @default(0)
  electrical   Float   @default(0)
  finishes     Float   @default(0)
  insulation   Float   @default(0)
  laborCost    Float   @default(0)
  total        Float   @default(0)
  breakdown    Json?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id        String  @id @default(cuid())
  projectId String
  type      String
  name      String
  status    String  @default("DRAFT")
  fileUrl   String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

// =====================
// APP-WIDE SETTINGS
// =====================

// Single-row table (id is always the fixed string below) — SUPERADMIN-only
// controls that aren't tied to any one user or project. Started with just
// the paid-AI-provider fallback gate; add more columns here as needed
// rather than creating a new singleton table per setting.
model AppSettings {
  id                   String   @id @default("singleton")
  allowPaidAiProviders Boolean  @default(false)
  updatedAt            DateTime @updatedAt
}
